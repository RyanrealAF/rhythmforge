 import numpy as np
 
+
+def _safe_tempo(raw_tempo) -> float:
+    tempo = float(np.atleast_1d(raw_tempo)[0]) if raw_tempo is not None else 0.0
+    if not np.isfinite(tempo) or tempo <= 0:
